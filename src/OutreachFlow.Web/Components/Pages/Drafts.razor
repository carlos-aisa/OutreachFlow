@page "/drafts"
@rendermode InteractiveServer
@using Microsoft.Extensions.Localization
@using OutreachFlow.Application.EmailDrafts
@using OutreachFlow.Web
@using OutreachFlow.Domain.EmailDrafts
@using OutreachFlow.Web.EmailDrafts
@inject EmailDraftApiClient DraftClient
@inject IStringLocalizer<SharedResource> Localizer

<PageTitle>@Localizer["Drafts.PageTitle"]</PageTitle>

<div class="page-shell">
<div class="page-intro">
    <p class="page-kicker">@Localizer["Drafts.PageTitle"]</p>
    <h1 class="page-title">@Localizer["Drafts.PageTitle"]</h1>
    <p class="page-description">@Localizer["Drafts.Description"]</p>
</div>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger page-section" role="alert">@errorMessage</div>
}

<section class="card mb-4">
    <div class="card-header">
        <h2 class="workspace-card-title mb-0">@Localizer["Drafts.FiltersTitle"]</h2>
    </div>
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label">@Localizer["Common.Status"]</label>
                <select class="form-select" @bind="selectedStatus">
                    <option value="">@Localizer["Common.Any"]</option>
                    @foreach (var status in statusValues)
                    {
                        <option value="@status">@SharedResourceDisplayNames.EmailDraftStatus(Localizer, status)</option>
                    }
                </select>
            </div>
            <div class="col-md-8 d-flex gap-2">
                <button class="btn btn-primary" @onclick="LoadDraftsAsync" disabled="@isLoading">@Localizer["Common.ApplyFilters"]</button>
                <button class="btn btn-outline-secondary" @onclick="ClearFiltersAsync" disabled="@isLoading">@Localizer["Common.Clear"]</button>
            </div>
        </div>
    </div>
</section>

<section class="card">
    <div class="card-header">
        <h2 class="workspace-card-title mb-0">@Localizer["Drafts.ListTitle"]</h2>
    </div>
    <div class="card-body">
        @if (isLoading)
        {
            <p class="mb-0">@Localizer["Drafts.Loading"]</p>
        }
        else if (drafts.Count == 0)
        {
            <p class="mb-0">@Localizer["Drafts.Empty"]</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm align-middle">
                    <thead>
                        <tr>
                            <th>@Localizer["Common.Contact"]</th>
                            <th>@Localizer["Common.Email"]</th>
                            <th>@Localizer["Common.Status"]</th>
                            <th>@Localizer["Common.Updated"]</th>
                            <th>@Localizer["Common.Approved"]</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var draft in drafts)
                        {
                            <tr>
                                <td>@draft.ContactDisplayName</td>
                                <td>@draft.ContactEmail</td>
                                <td>@SharedResourceDisplayNames.EmailDraftStatus(Localizer, draft.Status)</td>
                                <td>@draft.UpdatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                                <td>@FormatDate(draft.ApprovedAt)</td>
                                <td class="text-end">
                                    <a class="btn btn-sm btn-outline-primary" href="@($"/drafts/{draft.Id}")">
                                        @Localizer["Drafts.ReviewAction"]
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</section>
</div>

@code {
    private readonly EmailDraftStatus[] statusValues = Enum.GetValues<EmailDraftStatus>();
    private IReadOnlyList<EmailDraftDto> drafts = [];
    private string? selectedStatus;
    private bool isLoading;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadDraftsAsync();
    }

    private async Task LoadDraftsAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            drafts = await DraftClient.ListAsync(ParseStatus(selectedStatus));
        }
        catch (InvalidOperationException exception)
        {
            errorMessage = exception.Message;
        }
        catch (HttpRequestException exception)
        {
            errorMessage = $"{Localizer["Common.ApiUnavailablePrefix"]}: {exception.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ClearFiltersAsync()
    {
        selectedStatus = null;
        await LoadDraftsAsync();
    }

    private static EmailDraftStatus? ParseStatus(string? value)
    {
        return Enum.TryParse<EmailDraftStatus>(value, out var status) ? status : null;
    }

    private static string FormatDate(DateTimeOffset? value)
    {
        return value is null ? "-" : value.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm");
    }
}
