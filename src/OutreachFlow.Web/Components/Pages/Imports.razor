@page "/imports"
@rendermode InteractiveServer
@using System.Text
@using Microsoft.Extensions.Localization
@using OutreachFlow.Application.ContactImports
@using OutreachFlow.Application.Tags
@using OutreachFlow.Web
@using OutreachFlow.Web.ContactImports
@using OutreachFlow.Web.Tags
@inject ContactImportApiClient ImportClient
@inject TagApiClient TagClient
@inject IStringLocalizer<SharedResource> Localizer

<PageTitle>@Localizer["Imports.PageTitle"]</PageTitle>

<div class="page-shell">
<div class="page-intro">
    <p class="page-kicker">@Localizer["Imports.PageTitle"]</p>
    <h1 class="page-title">@Localizer["Imports.PageTitle"]</h1>
    <p class="page-description">@Localizer["Imports.Description"]</p>
</div>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger page-section" role="alert">@errorMessage</div>
}

@if (!string.IsNullOrWhiteSpace(successMessage))
{
    <div class="alert alert-success page-section" role="alert">@successMessage</div>
}

<section class="card mb-4">
    <div class="card-header">
        <h2 class="workspace-card-title mb-0">@Localizer["Imports.CsvTitle"]</h2>
    </div>
    <div class="card-body">
        <div class="mb-3">
            <label class="form-label" for="csv-file">@Localizer["Imports.FileLabel"]</label>
            <InputFile id="csv-file" OnChange="OnFileSelectedAsync" accept=".csv,text/csv" />
            @if (!string.IsNullOrWhiteSpace(fileName))
            {
                <div class="form-text">@Localizer["Imports.SelectedFile", fileName]</div>
            }
            <div class="form-text">@((MarkupString)Localizer["Imports.RequiredHeaders"].Value)</div>
        </div>

        <div class="d-flex gap-2">
            <button class="btn btn-primary" @onclick="PreviewAsync" disabled="@isBusy">@Localizer["Imports.PreviewAction"]</button>
            <button class="btn btn-outline-secondary" @onclick="ClearPreview" disabled="@isBusy">@Localizer["Common.Clear"]</button>
        </div>
    </div>
</section>

@if (preview is not null)
{
    <section class="card mb-4">
        <div class="card-header">
            <h2 class="workspace-card-title mb-0">@Localizer["Imports.SummaryTitle"]</h2>
        </div>
        <div class="card-body">
            <div class="row g-3 mb-3">
                <div class="col-md-3"><strong>@Localizer["Imports.TotalRows"]:</strong> @preview.TotalRows</div>
                <div class="col-md-3 text-success"><strong>@Localizer["Imports.ValidRows"]:</strong> @preview.ValidRows</div>
                <div class="col-md-3 text-warning"><strong>@Localizer["Imports.DuplicateRows"]:</strong> @preview.DuplicateRows</div>
                <div class="col-md-3 text-danger"><strong>@Localizer["Imports.InvalidRows"]:</strong> @preview.InvalidRows</div>
            </div>

            <h3 class="h6">@Localizer["Imports.AssignTags"]</h3>
            <div class="row g-2 mb-3">
                @if (tags.Count == 0)
                {
                    <div class="col-12 text-muted">@Localizer["Imports.NoTags"]</div>
                }
                else
                {
                    @foreach (var tag in tags)
                    {
                        <div class="col-md-4">
                            <div class="form-check">
                                <input class="form-check-input"
                                       type="checkbox"
                                       id="@($"tag-{tag.Id}")"
                                       checked="@selectedTagIds.Contains(tag.Id)"
                                       @onchange="eventArgs => OnTagSelectionChanged(tag.Id, eventArgs.Value)" />
                                <label class="form-check-label" for="@($"tag-{tag.Id}")">
                                    @tag.Name
                                    @if (!string.IsNullOrWhiteSpace(tag.Category))
                                    {
                                        <span class="text-muted">(@tag.Category)</span>
                                    }
                                </label>
                            </div>
                        </div>
                    }
                }
            </div>

            <button class="btn btn-success" @onclick="CommitAsync" disabled="@isBusy || preview.ValidRows == 0">
                @Localizer["Imports.CommitAction"]
            </button>
        </div>
    </section>

    <section class="card mb-4">
        <div class="card-header">
            <h2 class="workspace-card-title mb-0">@Localizer["Imports.RowsTitle"]</h2>
        </div>
        <div class="table-responsive">
            <table class="table table-striped mb-0">
                <thead>
                    <tr>
                        <th scope="col">@Localizer["Common.Row"]</th>
                        <th scope="col">@Localizer["Common.DisplayName"]</th>
                        <th scope="col">@Localizer["Common.Email"]</th>
                        <th scope="col">@Localizer["Common.Status"]</th>
                        <th scope="col">@Localizer["Common.Message"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in preview.Rows)
                    {
                        <tr>
                            <td>@row.RowNumber</td>
                            <td>@(string.IsNullOrWhiteSpace(row.DisplayName) ? "-" : row.DisplayName)</td>
                            <td>@(string.IsNullOrWhiteSpace(row.Email) ? "-" : row.Email)</td>
                            <td>
                                @if (row.IsValid)
                                {
                                    <span class="badge bg-success">@Localizer["Imports.ValidRows"]</span>
                                }
                                else if (row.IsDuplicate)
                                {
                                    <span class="badge bg-warning text-dark">@Localizer["Imports.DuplicateRows"]</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">@Localizer["Imports.InvalidRows"]</span>
                                }
                            </td>
                            <td>@(string.IsNullOrWhiteSpace(row.Message) ? "-" : row.Message)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
}

<section class="card">
    <div class="card-header">
        <h2 class="workspace-card-title mb-0">@Localizer["Imports.JobsTitle"]</h2>
    </div>
    <div class="table-responsive">
        <table class="table table-striped mb-0">
            <thead>
                <tr>
                    <th scope="col">@Localizer["Common.Created"]</th>
                    <th scope="col">@Localizer["Common.File"]</th>
                    <th scope="col">@Localizer["Common.Status"]</th>
                    <th scope="col">@Localizer["Common.Created"]</th>
                    <th scope="col">@Localizer["Imports.DuplicateRows"]</th>
                    <th scope="col">@Localizer["Imports.InvalidRows"]</th>
                </tr>
            </thead>
            <tbody>
                @if (jobs.Count == 0)
                {
                    <tr><td colspan="6">@Localizer["Imports.NoJobs"]</td></tr>
                }
                else
                {
                    @foreach (var job in jobs)
                    {
                        <tr>
                            <td>@job.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                            <td>@job.FileName</td>
                            <td>@SharedResourceDisplayNames.ImportJobStatus(Localizer, job.Status)</td>
                            <td>@job.CreatedCount</td>
                            <td>@job.DuplicateRows</td>
                            <td>@job.InvalidRows</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</section>
</div>

@code {
    private IReadOnlyList<TagDto> tags = [];
    private IReadOnlyList<ImportJobDto> jobs = [];
    private ContactImportPreviewResult? preview;
    private HashSet<Guid> selectedTagIds = [];
    private string? fileName;
    private string? csvContent;
    private string? errorMessage;
    private string? successMessage;
    private bool isLoading;
    private bool isSaving;

    private bool isBusy => isLoading || isSaving;

    protected override async Task OnInitializedAsync()
    {
        await LoadReferenceDataAsync();
    }

    private async Task LoadReferenceDataAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            tags = await TagClient.ListAsync();
            jobs = await ImportClient.ListJobsAsync(limit: 20);
        }
        catch (InvalidOperationException exception)
        {
            errorMessage = exception.Message;
        }
        catch (HttpRequestException exception)
        {
            errorMessage = $"{Localizer["Common.ApiUnavailablePrefix"]}: {exception.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task OnFileSelectedAsync(InputFileChangeEventArgs eventArgs)
    {
        errorMessage = null;
        successMessage = null;
        preview = null;

        var file = eventArgs.File;
        fileName = file.Name;

        try
        {
            await using var stream = file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
            using var reader = new StreamReader(stream, Encoding.UTF8);
            csvContent = await reader.ReadToEndAsync();
        }
        catch (IOException exception)
        {
            csvContent = null;
            errorMessage = Localizer["Imports.ReadFileError", exception.Message];
        }
    }

    private async Task PreviewAsync()
    {
        errorMessage = null;
        successMessage = null;
        isSaving = true;

        try
        {
            if (string.IsNullOrWhiteSpace(fileName) || string.IsNullOrWhiteSpace(csvContent))
            {
                throw new InvalidOperationException(Localizer["Imports.SelectFileBeforePreview"]);
            }

            preview = await ImportClient.PreviewAsync(new ContactImportPreviewRequest(fileName, csvContent));
        }
        catch (InvalidOperationException exception)
        {
            errorMessage = exception.Message;
        }
        catch (HttpRequestException exception)
        {
            errorMessage = $"{Localizer["Common.ApiUnavailablePrefix"]}: {exception.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task CommitAsync()
    {
        errorMessage = null;
        successMessage = null;
        isSaving = true;

        try
        {
            if (string.IsNullOrWhiteSpace(fileName) || string.IsNullOrWhiteSpace(csvContent))
            {
                throw new InvalidOperationException(Localizer["Imports.SelectFileBeforeCommit"]);
            }

            var result = await ImportClient.CommitAsync(new ContactImportCommitRequest(
                fileName,
                csvContent,
                selectedTagIds.ToArray()));

            successMessage = Localizer["Imports.SuccessMessage", result.CreatedCount, result.DuplicateCount, result.InvalidCount];
            preview = null;
            selectedTagIds.Clear();
            await LoadReferenceDataAsync();
        }
        catch (InvalidOperationException exception)
        {
            errorMessage = exception.Message;
        }
        catch (HttpRequestException exception)
        {
            errorMessage = $"{Localizer["Common.ApiUnavailablePrefix"]}: {exception.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private void ClearPreview()
    {
        preview = null;
        selectedTagIds.Clear();
        successMessage = null;
        errorMessage = null;
    }

    private void OnTagSelectionChanged(Guid tagId, object? value)
    {
        var isChecked = value as bool? ?? false;

        if (isChecked)
        {
            selectedTagIds.Add(tagId);
            return;
        }

        selectedTagIds.Remove(tagId);
    }
}
