@page "/sender-profiles"
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using Microsoft.Extensions.Localization
@using OutreachFlow.Application.SenderProfiles
@using OutreachFlow.Domain.SenderProfiles
@using OutreachFlow.Web
@using OutreachFlow.Web.SenderProfiles
@inject SenderProfileApiClient SenderProfileClient
@inject IStringLocalizer<SharedResource> Localizer

<PageTitle>@Localizer["SenderProfiles.PageTitle"]</PageTitle>

<div class="page-shell">
<div class="page-intro">
    <p class="page-kicker">@Localizer["SenderProfiles.PageTitle"]</p>
    <h1 class="page-title">@Localizer["SenderProfiles.PageTitle"]</h1>
    <p class="page-description">@Localizer["SenderProfiles.Description"]</p>
</div>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger page-section" role="alert">@errorMessage</div>
}

<section class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h2 class="workspace-card-title mb-0">@(editingId is null ? Localizer["SenderProfiles.Form.CreateTitle"] : Localizer["SenderProfiles.Form.EditTitle"])</h2>
        @if (editingId is not null)
        {
            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ResetForm">@Localizer["Common.CancelEdit"]</button>
        }
    </div>
    <div class="card-body">
        <EditForm Model="form" OnValidSubmit="SaveAsync">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label" for="sender-name">@Localizer["Common.Name"]</label>
                    <InputText id="sender-name" class="form-control" @bind-Value="form.Name" />
                </div>
                <div class="col-md-4">
                    <label class="form-label" for="sender-email">@Localizer["Common.Email"]</label>
                    <InputText id="sender-email" class="form-control" @bind-Value="form.Email" />
                </div>
                <div class="col-md-4">
                    <label class="form-label" for="sender-phone">@Localizer["Common.Phone"]</label>
                    <InputText id="sender-phone" class="form-control" @bind-Value="form.Phone" />
                </div>
                <div class="col-md-4">
                    <label class="form-label" for="sender-organization">@Localizer["Common.OrganizationName"]</label>
                    <InputText id="sender-organization" class="form-control" @bind-Value="form.OrganizationName" />
                </div>
                <div class="col-md-4">
                    <label class="form-label" for="sender-website">@Localizer["Common.Website"]</label>
                    <InputText id="sender-website" class="form-control" @bind-Value="form.Website" />
                </div>
                <div class="col-md-4 d-flex align-items-end gap-4">
                    <div class="form-check">
                        <InputCheckbox id="sender-default" class="form-check-input" @bind-Value="form.IsDefault" />
                        <label class="form-check-label" for="sender-default">@Localizer["Common.Default"]</label>
                    </div>
                    <div class="form-check">
                        <InputCheckbox id="sender-active" class="form-check-input" @bind-Value="form.IsActive" />
                        <label class="form-check-label" for="sender-active">@Localizer["Common.Active"]</label>
                    </div>
                </div>
                <div class="col-12">
                    <label class="form-label" for="sender-signature-format">@Localizer["Common.SignatureFormat"]</label>
                    <InputSelect id="sender-signature-format" class="form-select" @bind-Value="form.SignatureFormat">
                        <option value="">@Localizer["Common.SignatureFormatPlaceholder"]</option>
                        @foreach (var signatureFormat in SignatureFormats)
                        {
                            <option value="@signatureFormat">@signatureFormat</option>
                        }
                    </InputSelect>
                </div>
                <div class="col-12">
                    <label class="form-label" for="sender-signature">@Localizer["Common.Signature"]</label>
                    <InputTextArea id="sender-signature" class="form-control" @bind-Value="form.Signature" />
                </div>
                <div class="col-12">
                    <button type="submit" class="btn btn-success" disabled="@isSaving">@Localizer["SenderProfiles.Form.SaveAction"]</button>
                </div>
            </div>
        </EditForm>
    </div>
</section>

<section class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h2 class="workspace-card-title mb-0">@Localizer["SenderProfiles.List.Title"]</h2>
        <span class="badge text-bg-secondary">@Localizer["SenderProfiles.List.Count", senderProfiles.Count]</span>
    </div>
    <div class="table-responsive">
        <table class="table table-striped table-hover mb-0">
            <thead>
                <tr>
                    <th scope="col">@Localizer["Common.Name"]</th>
                    <th scope="col">@Localizer["Common.Email"]</th>
                    <th scope="col">@Localizer["Common.Organization"]</th>
                    <th scope="col">@Localizer["Common.Default"]</th>
                    <th scope="col">@Localizer["Common.Active"]</th>
                    <th scope="col">@Localizer["Common.Actions"]</th>
                </tr>
            </thead>
            <tbody>
                @if (isLoading)
                {
                    <tr><td colspan="6">@Localizer["SenderProfiles.List.Loading"]</td></tr>
                }
                else if (senderProfiles.Count == 0)
                {
                    <tr><td colspan="6">@Localizer["SenderProfiles.List.Empty"]</td></tr>
                }
                else
                {
                    @foreach (var senderProfile in senderProfiles)
                    {
                        <tr>
                            <td>@senderProfile.Name</td>
                            <td>@senderProfile.Email</td>
                            <td>@(senderProfile.OrganizationName ?? "-")</td>
                            <td>@(senderProfile.IsDefault ? Localizer["Common.Yes"] : Localizer["Common.No"])</td>
                            <td>@(senderProfile.IsActive ? Localizer["Common.Yes"] : Localizer["Common.No"])</td>
                            <td>
                                <button type="button" class="btn btn-sm btn-outline-primary me-2" @onclick="() => Edit(senderProfile)">@Localizer["Common.Edit"]</button>
                                <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => DeactivateAsync(senderProfile.Id)" disabled="@(!senderProfile.IsActive)">@Localizer["Common.Deactivate"]</button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</section>
</div>

@code {
    private static readonly SenderSignatureFormat[] SignatureFormats = Enum.GetValues<SenderSignatureFormat>();

    private IReadOnlyList<SenderProfileDto> senderProfiles = [];
    private SenderProfileFormModel form = new();
    private Guid? editingId;
    private string? errorMessage;
    private bool isLoading;
    private bool isSaving;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            senderProfiles = await SenderProfileClient.ListAsync();
        }
        catch (InvalidOperationException exception)
        {
            errorMessage = exception.Message;
        }
        catch (HttpRequestException exception)
        {
            errorMessage = $"{Localizer["Common.ApiUnavailablePrefix"]}: {exception.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SaveAsync()
    {
        isSaving = true;
        errorMessage = null;

        try
        {
            if (editingId is Guid id)
            {
                await SenderProfileClient.UpdateAsync(id, new UpdateSenderProfileRequest(
                    form.Name,
                    form.Email,
                    form.Phone,
                    form.OrganizationName,
                    form.Website,
                    form.Signature,
                    form.IsDefault,
                    form.IsActive,
                    form.SignatureFormat));
            }
            else
            {
                await SenderProfileClient.CreateAsync(new CreateSenderProfileRequest(
                    form.Name,
                    form.Email,
                    form.Phone,
                    form.OrganizationName,
                    form.Website,
                    form.Signature,
                    form.IsDefault,
                    form.SignatureFormat));
            }

            ResetForm();
            await LoadAsync();
        }
        catch (InvalidOperationException exception)
        {
            errorMessage = exception.Message;
        }
        catch (HttpRequestException exception)
        {
            errorMessage = $"{Localizer["Common.ApiUnavailablePrefix"]}: {exception.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private void Edit(SenderProfileDto senderProfile)
    {
        editingId = senderProfile.Id;
        form = new SenderProfileFormModel
        {
            Name = senderProfile.Name,
            Email = senderProfile.Email,
            Phone = senderProfile.Phone,
            OrganizationName = senderProfile.OrganizationName,
            Website = senderProfile.Website,
            SignatureFormat = senderProfile.SignatureFormat,
            Signature = senderProfile.Signature,
            IsDefault = senderProfile.IsDefault,
            IsActive = senderProfile.IsActive
        };
    }

    private async Task DeactivateAsync(Guid id)
    {
        try
        {
            await SenderProfileClient.DeactivateAsync(id);
            await LoadAsync();
        }
        catch (InvalidOperationException exception)
        {
            errorMessage = exception.Message;
        }
        catch (HttpRequestException exception)
        {
            errorMessage = $"{Localizer["Common.ApiUnavailablePrefix"]}: {exception.Message}";
        }
    }

    private void ResetForm()
    {
        editingId = null;
        form = new SenderProfileFormModel();
    }

    private sealed class SenderProfileFormModel
    {
        [Required]
        public string Name { get; set; } = string.Empty;

        [Required]
        [EmailAddress]
        public string Email { get; set; } = string.Empty;

        public string? Phone { get; set; }

        public string? OrganizationName { get; set; }

        public string? Website { get; set; }

        public SenderSignatureFormat? SignatureFormat { get; set; }

        public string? Signature { get; set; }

        public bool IsDefault { get; set; }

        public bool IsActive { get; set; } = true;
    }
}
