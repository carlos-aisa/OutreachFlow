@page "/contacts/{ContactId:guid}"
@rendermode InteractiveServer
@using OutreachFlow.Application.ContactActivities
@using OutreachFlow.Application.Contacts
@using OutreachFlow.Application.FollowUps
@using OutreachFlow.Application.Tags
@using OutreachFlow.Web.Contacts
@using OutreachFlow.Web.FollowUps
@using OutreachFlow.Web.Tags
@inject ContactApiClient ContactClient
@inject FollowUpTaskApiClient FollowUpClient
@inject TagApiClient TagClient

<PageTitle>Contact Detail</PageTitle>

<h1>Contact Detail</h1>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger" role="alert">@errorMessage</div>
}

@if (isLoading)
{
    <p>Loading contact detail...</p>
}
else if (contact is null)
{
    <p>Contact not found.</p>
}
else
{
    <section class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h2 class="h5 mb-0">Contact summary</h2>
            <a class="btn btn-sm btn-outline-primary" href="/contacts">Back to contacts</a>
        </div>
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3">Display name</dt>
                <dd class="col-sm-9">@contact.DisplayName</dd>

                <dt class="col-sm-3">Email</dt>
                <dd class="col-sm-9">@contact.Email</dd>

                <dt class="col-sm-3">Organization</dt>
                <dd class="col-sm-9">@(contact.OrganizationName ?? "-")</dd>

                <dt class="col-sm-3">Status</dt>
                <dd class="col-sm-9">@contact.Status</dd>

                <dt class="col-sm-3">Do not contact</dt>
                <dd class="col-sm-9">@(contact.DoNotContact ? "Yes" : "No")</dd>

                <dt class="col-sm-3">Role</dt>
                <dd class="col-sm-9">@(contact.Role ?? "-")</dd>

                <dt class="col-sm-3">Source</dt>
                <dd class="col-sm-9">@(contact.Source ?? "-")</dd>

                <dt class="col-sm-3">Phone</dt>
                <dd class="col-sm-9">@(contact.Phone ?? "-")</dd>

                <dt class="col-sm-3">Last contacted</dt>
                <dd class="col-sm-9">@FormatDate(contact.LastContactedAt)</dd>
            </dl>
        </div>
    </section>

    <section class="card mb-4">
        <div class="card-header">
            <h2 class="h5 mb-0">Contact tags</h2>
        </div>
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-md-9">
                    <label class="form-label" for="contact-tag-select">Add tag</label>
                    <select id="contact-tag-select"
                            class="form-select"
                            @bind="selectedTagId"
                            disabled="@isTagSaving">
                        <option value="">Select a tag</option>
                        @foreach (var tag in assignableTags)
                        {
                            <option value="@tag.Id">@FormatTag(tag.Name, tag.Category)</option>
                        }
                    </select>
                    @if (assignableTags.Count == 0)
                    {
                        @if (tags.Count == 0)
                        {
                            <div class="form-text">No tags are available. Create tags first.</div>
                        }
                        else
                        {
                            <div class="form-text">All available tags are already assigned to this contact.</div>
                        }
                    }
                </div>
                <div class="col-md-3">
                    <button type="button"
                            class="btn btn-primary w-100"
                            id="assign-contact-tag"
                            @onclick="AssignTagAsync"
                            disabled="@(!CanAssignTag)">
                        Add tag
                    </button>
                </div>
            </div>

            @if (contact.Tags.Count == 0)
            {
                <p class="text-muted mt-3 mb-0">No tags assigned yet.</p>
            }
            else
            {
                <div class="table-responsive mt-3">
                    <table class="table table-sm align-middle mb-0">
                        <thead>
                            <tr>
                                <th scope="col">Tag</th>
                                <th scope="col" class="text-end">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var tag in contact.Tags)
                            {
                                <tr>
                                    <td>@FormatTag(tag.Name, tag.Category)</td>
                                    <td class="text-end">
                                        <button type="button"
                                                class="btn btn-sm btn-outline-danger"
                                                @onclick="() => RemoveTagAsync(tag.Id)"
                                                disabled="@isTagSaving">
                                            Remove
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </section>

    <section class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h2 class="h5 mb-0">Activity timeline</h2>
            <span class="badge text-bg-secondary">@activities.Count events</span>
        </div>
        <div class="card-body">
            @if (activities.Count == 0)
            {
                <p class="mb-0">No activity has been recorded for this contact yet.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0">
                        <thead>
                            <tr>
                                <th scope="col">Occurred</th>
                                <th scope="col">Type</th>
                                <th scope="col">Subject</th>
                                <th scope="col">Body preview</th>
                                <th scope="col">Metadata</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var activity in activities)
                            {
                                <tr>
                                    <td>@FormatDate(activity.OccurredAt)</td>
                                    <td>@activity.Type</td>
                                    <td>@(string.IsNullOrWhiteSpace(activity.Subject) ? "-" : activity.Subject)</td>
                                    <td>@(string.IsNullOrWhiteSpace(activity.BodyPreview) ? "-" : activity.BodyPreview)</td>
                                    <td><code>@(string.IsNullOrWhiteSpace(activity.MetadataJson) ? "-" : activity.MetadataJson)</code></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </section>

    <section class="card mt-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h2 class="h5 mb-0">Follow-up tasks</h2>
            <a class="btn btn-sm btn-outline-primary" href="/follow-ups">Manage follow-ups</a>
        </div>
        <div class="card-body">
            @if (followUps.Count == 0)
            {
                <p class="mb-0">No follow-up tasks for this contact.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm mb-0">
                        <thead>
                            <tr>
                                <th scope="col">Due</th>
                                <th scope="col">Type</th>
                                <th scope="col">Notes</th>
                                <th scope="col">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var task in followUps)
                            {
                                <tr>
                                    <td>@FormatDate(task.DueAt)</td>
                                    <td>@task.Type</td>
                                    <td>@(string.IsNullOrWhiteSpace(task.Notes) ? "-" : task.Notes)</td>
                                    <td>@(task.IsCompleted ? "Completed" : "Pending")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </section>
}

@code {
    [Parameter]
    public Guid ContactId { get; set; }

    private ContactDto? contact;
    private IReadOnlyList<ContactActivityDto> activities = [];
    private IReadOnlyList<FollowUpTaskDto> followUps = [];
    private IReadOnlyList<TagDto> tags = [];
    private IReadOnlyList<TagDto> assignableTags = [];
    private bool isLoading;
    private bool isTagSaving;
    private string? errorMessage;
    private string? selectedTagId;

    protected override async Task OnParametersSetAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            contact = await ContactClient.GetByIdAsync(ContactId);
            activities = await ContactClient.ListActivitiesAsync(ContactId);
            followUps = await FollowUpClient.ListAsync(new FollowUpTaskFilterRequest(
                ContactId,
                IsCompleted: null,
                DueFrom: null,
                DueTo: null,
                Limit: 20));
            tags = await TagClient.ListAsync();
            UpdateAssignableTagSelection(contact);
        }
        catch (InvalidOperationException exception)
        {
            errorMessage = exception.Message;
            contact = null;
            activities = [];
            followUps = [];
            tags = [];
            assignableTags = [];
            selectedTagId = null;
        }
        catch (HttpRequestException exception)
        {
            errorMessage = $"Could not reach the OutreachFlow API: {exception.Message}";
            contact = null;
            activities = [];
            followUps = [];
            tags = [];
            assignableTags = [];
            selectedTagId = null;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task AssignTagAsync()
    {
        if (contact is null || !Guid.TryParse(selectedTagId, out var tagId))
        {
            return;
        }

        await SaveTagChangeAsync(async () =>
        {
            await ContactClient.AssignTagAsync(ContactId, tagId);
            await RefreshContactTagsAsync();
        });
    }

    private async Task RemoveTagAsync(Guid tagId)
    {
        if (contact is null)
        {
            return;
        }

        await SaveTagChangeAsync(async () =>
        {
            await ContactClient.RemoveTagAsync(ContactId, tagId);
            await RefreshContactTagsAsync();
        });
    }

    private async Task SaveTagChangeAsync(Func<Task> operation)
    {
        isTagSaving = true;
        errorMessage = null;

        try
        {
            await operation();
        }
        catch (InvalidOperationException exception)
        {
            errorMessage = exception.Message;
        }
        catch (HttpRequestException exception)
        {
            errorMessage = $"Could not reach the OutreachFlow API: {exception.Message}";
        }
        finally
        {
            isTagSaving = false;
        }
    }

    private async Task RefreshContactTagsAsync()
    {
        contact = await ContactClient.GetByIdAsync(ContactId);
        UpdateAssignableTagSelection(contact);
    }

    private void UpdateAssignableTagSelection(ContactDto? currentContact)
    {
        assignableTags = BuildAssignableTags(currentContact, tags);

        if (assignableTags.Count == 0)
        {
            selectedTagId = null;
            return;
        }

        if (!Guid.TryParse(selectedTagId, out var selectedGuid) ||
            assignableTags.All(tag => tag.Id != selectedGuid))
        {
            selectedTagId = assignableTags[0].Id.ToString();
        }
    }

    private static IReadOnlyList<TagDto> BuildAssignableTags(
        ContactDto? currentContact,
        IReadOnlyList<TagDto> availableTags)
    {
        if (currentContact is null || availableTags.Count == 0)
        {
            return [];
        }

        var assignedTagIds = currentContact.Tags
            .Select(tag => tag.Id)
            .ToHashSet();

        return availableTags
            .Where(tag => !assignedTagIds.Contains(tag.Id))
            .ToArray();
    }

    private static string FormatTag(string name, string? category)
    {
        return string.IsNullOrWhiteSpace(category) ? name : $"{category}: {name}";
    }

    private bool CanAssignTag => !isTagSaving &&
                                 assignableTags.Count > 0 &&
                                 Guid.TryParse(selectedTagId, out _);

    private static string FormatDate(DateTimeOffset? value)
    {
        return value is null ? "-" : value.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm");
    }
}
