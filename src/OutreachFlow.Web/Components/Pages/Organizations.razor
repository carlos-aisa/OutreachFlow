@page "/organizations"
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using Microsoft.Extensions.Localization
@using OutreachFlow.Application.Organizations
@using OutreachFlow.Web
@using OutreachFlow.Web.Organizations
@inject OrganizationApiClient OrganizationClient
@inject IStringLocalizer<SharedResource> Localizer

<PageTitle>@Localizer["Organizations.PageTitle"]</PageTitle>

<div class="page-shell">
<div class="page-intro">
    <p class="page-kicker">@Localizer["Organizations.PageTitle"]</p>
    <h1 class="page-title">@Localizer["Organizations.PageTitle"]</h1>
    <p class="page-description">@Localizer["Organizations.Description"]</p>
</div>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger page-section" role="alert">@errorMessage</div>
}

<section class="card mb-4">
    <div class="card-header">
        <h2 class="workspace-card-title mb-0">@Localizer["Organizations.Form.CreateTitle"]</h2>
    </div>
    <div class="card-body">
        <EditForm Model="newOrganization" OnValidSubmit="CreateOrganizationAsync">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label" for="organization-name">@Localizer["Common.Name"]</label>
                    <InputText id="organization-name" class="form-control" @bind-Value="newOrganization.Name" />
                </div>
                <div class="col-md-4">
                    <label class="form-label" for="organization-type">@Localizer["Common.Type"]</label>
                    <InputText id="organization-type" class="form-control" @bind-Value="newOrganization.Type" />
                </div>
                <div class="col-md-4">
                    <label class="form-label" for="organization-website">@Localizer["Common.Website"]</label>
                    <InputText id="organization-website" class="form-control" @bind-Value="newOrganization.Website" />
                </div>
                <div class="col-md-4">
                    <label class="form-label" for="organization-city">@Localizer["Common.City"]</label>
                    <InputText id="organization-city" class="form-control" @bind-Value="newOrganization.City" />
                </div>
                <div class="col-md-4">
                    <label class="form-label" for="organization-province">@Localizer["Common.Province"]</label>
                    <InputText id="organization-province" class="form-control" @bind-Value="newOrganization.Province" />
                </div>
                <div class="col-md-4">
                    <label class="form-label" for="organization-country">@Localizer["Common.Country"]</label>
                    <InputText id="organization-country" class="form-control" @bind-Value="newOrganization.Country" />
                </div>
                <div class="col-12">
                    <label class="form-label" for="organization-notes">@Localizer["Common.Notes"]</label>
                    <InputTextArea id="organization-notes" class="form-control" @bind-Value="newOrganization.Notes" />
                </div>
                <div class="col-12">
                    <button type="submit" class="btn btn-success" disabled="@isSaving">@Localizer["Organizations.Form.CreateAction"]</button>
                </div>
            </div>
        </EditForm>
    </div>
</section>

<section class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h2 class="workspace-card-title mb-0">@Localizer["Organizations.List.Title"]</h2>
        <span class="badge text-bg-secondary">@Localizer["Organizations.List.Count", organizations.Count]</span>
    </div>
    <div class="table-responsive">
        <table class="table table-striped table-hover mb-0">
            <thead>
                <tr>
                    <th scope="col">@Localizer["Common.Name"]</th>
                    <th scope="col">@Localizer["Common.Type"]</th>
                    <th scope="col">@Localizer["Common.Website"]</th>
                    <th scope="col">@Localizer["Common.City"]</th>
                    <th scope="col">@Localizer["Common.Country"]</th>
                </tr>
            </thead>
            <tbody>
                @if (isLoading)
                {
                    <tr>
                        <td colspan="5">@Localizer["Organizations.List.Loading"]</td>
                    </tr>
                }
                else if (organizations.Count == 0)
                {
                    <tr>
                        <td colspan="5">@Localizer["Organizations.List.Empty"]</td>
                    </tr>
                }
                else
                {
                    @foreach (var organization in organizations)
                    {
                        <tr>
                            <td>@organization.Name</td>
                            <td>@(organization.Type ?? "-")</td>
                            <td>@(organization.Website ?? "-")</td>
                            <td>@(organization.City ?? "-")</td>
                            <td>@(organization.Country ?? "-")</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</section>
</div>

@code {
    private IReadOnlyList<OrganizationDto> organizations = [];
    private OrganizationFormModel newOrganization = new();
    private string? errorMessage;
    private bool isLoading;
    private bool isSaving;

    protected override async Task OnInitializedAsync()
    {
        await LoadOrganizationsAsync();
    }

    private async Task LoadOrganizationsAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            organizations = await OrganizationClient.ListAsync();
        }
        catch (InvalidOperationException exception)
        {
            errorMessage = exception.Message;
        }
        catch (HttpRequestException exception)
        {
            errorMessage = $"{Localizer["Common.ApiUnavailablePrefix"]}: {exception.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task CreateOrganizationAsync()
    {
        isSaving = true;
        errorMessage = null;

        try
        {
            await OrganizationClient.CreateAsync(new CreateOrganizationRequest(
                newOrganization.Name,
                newOrganization.Type,
                newOrganization.Website,
                newOrganization.City,
                newOrganization.Province,
                newOrganization.Country,
                newOrganization.Notes));

            newOrganization = new OrganizationFormModel();
            await LoadOrganizationsAsync();
        }
        catch (InvalidOperationException exception)
        {
            errorMessage = exception.Message;
        }
        catch (HttpRequestException exception)
        {
            errorMessage = $"{Localizer["Common.ApiUnavailablePrefix"]}: {exception.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private sealed class OrganizationFormModel
    {
        [Required]
        public string Name { get; set; } = string.Empty;

        public string? Type { get; set; }

        public string? Website { get; set; }

        public string? City { get; set; }

        public string? Province { get; set; }

        public string? Country { get; set; }

        public string? Notes { get; set; }
    }
}
