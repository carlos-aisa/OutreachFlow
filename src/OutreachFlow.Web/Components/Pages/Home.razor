@page "/"
@rendermode InteractiveServer
@using OutreachFlow.Application.Contacts
@using OutreachFlow.Application.EmailDrafts
@using OutreachFlow.Application.FollowUps
@using OutreachFlow.Domain.Contacts
@using OutreachFlow.Domain.EmailDrafts
@using OutreachFlow.Web.Contacts
@using OutreachFlow.Web.EmailDrafts
@using OutreachFlow.Web.FollowUps
@using Microsoft.Extensions.Localization
@using OutreachFlow.Web
@inject ContactApiClient ContactClient
@inject EmailDraftApiClient DraftClient
@inject FollowUpTaskApiClient FollowUpClient
@inject IStringLocalizer<SharedResource> Localizer

<PageTitle>@Localizer["Nav.Dashboard"]</PageTitle>

<div class="page-shell">
    <div class="page-intro">
        <p class="page-kicker">@Localizer["Home.Overview"]</p>
        <h1 class="page-title">@Localizer["Nav.Dashboard"]</h1>
        <p class="page-description">@Localizer["Home.Description"]</p>
    </div>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger page-section" role="alert">@errorMessage</div>
    }

    <section class="summary-grid">
        <div class="card metric-card">
            <div class="card-body">
                <h2 class="metric-label">@Localizer["Home.NewContacts"]</h2>
                <p class="metric-value">@newContactsCount</p>
            </div>
        </div>
        <div class="card metric-card">
            <div class="card-body">
                <h2 class="metric-label">@Localizer["Home.NeedsReviewDrafts"]</h2>
                <p class="metric-value">@needsReviewDraftsCount</p>
            </div>
        </div>
        <div class="card metric-card">
            <div class="card-body">
                <h2 class="metric-label">@Localizer["Home.ApprovedDrafts"]</h2>
                <p class="metric-value">@approvedDraftsCount</p>
            </div>
        </div>
        <div class="card metric-card">
            <div class="card-body">
                <h2 class="metric-label">@Localizer["Home.FailedSends"]</h2>
                <p class="metric-value">@failedDraftsCount</p>
            </div>
        </div>
    </section>

    <section class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <div>
                <h2 class="workspace-card-title mb-0">@Localizer["Home.PendingFollowUps.Title"]</h2>
                <p class="workspace-card-subtitle">@Localizer["Home.PendingFollowUps.Subtitle"]</p>
            </div>
            <a class="btn btn-sm btn-outline-primary" href="/follow-ups">@Localizer["Home.PendingFollowUps.Action"]</a>
        </div>
        <div class="card-body">
            @if (pendingFollowUps.Count == 0)
            {
                <p class="mb-0">@Localizer["Home.PendingFollowUps.Empty"]</p>
            }
            else
            {
                <div class="list-group">
                    @foreach (var task in pendingFollowUps)
                    {
                        <div class="list-group-item d-flex justify-content-between align-items-center gap-3">
                            <div>
                                <div class="fw-semibold">
                                    <a href="@($"/contacts/{task.ContactId}")">@task.ContactDisplayName</a>
                                </div>
                                <div class="small text-muted">@SharedResourceDisplayNames.FollowUpTaskType(Localizer, task.Type)</div>
                            </div>
                            <span class="badge text-bg-secondary">@task.DueAt.ToLocalTime().ToString("yyyy-MM-dd")</span>
                        </div>
                    }
                </div>
            }
        </div>
    </section>
</div>

@code {
    private int newContactsCount;
    private int needsReviewDraftsCount;
    private int approvedDraftsCount;
    private int failedDraftsCount;
    private IReadOnlyList<FollowUpTaskDto> pendingFollowUps = [];
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboardAsync();
    }

    private async Task LoadDashboardAsync()
    {
        errorMessage = null;

        try
        {
            var newContacts = await ContactClient.ListAsync(new ContactFilterRequest(
                Search: null,
                TagId: null,
                Status: ContactStatus.New,
                DoNotContact: null,
                OrganizationId: null,
                LastContactedFrom: null,
                LastContactedTo: null));
            var needsReviewDrafts = await DraftClient.ListAsync(EmailDraftStatus.NeedsReview);
            var approvedDrafts = await DraftClient.ListAsync(EmailDraftStatus.Approved);
            var failedDrafts = await DraftClient.ListAsync(EmailDraftStatus.Failed);
            pendingFollowUps = await FollowUpClient.ListAsync(new FollowUpTaskFilterRequest(
                ContactId: null,
                IsCompleted: false,
                DueFrom: null,
                DueTo: null,
                Limit: 10));

            newContactsCount = newContacts.Count;
            needsReviewDraftsCount = needsReviewDrafts.Count;
            approvedDraftsCount = approvedDrafts.Count;
            failedDraftsCount = failedDrafts.Count;
        }
        catch (InvalidOperationException exception)
        {
            errorMessage = exception.Message;
        }
        catch (HttpRequestException exception)
        {
            errorMessage = $"{Localizer["Common.ApiUnavailablePrefix"]}: {exception.Message}";
        }
    }
}
