@page "/Error"
@using System.Diagnostics

@using Microsoft.Extensions.Localization
@using OutreachFlow.Web
@inject IStringLocalizer<SharedResource> Localizer

<PageTitle>@Localizer["Error.PageTitle"]</PageTitle>

<div class="page-shell">
    <div class="page-intro">
        <p class="page-kicker">@Localizer["Error.Kicker"]</p>
        <h1 class="page-title">@Localizer["Error.PageTitle"]</h1>
        <p class="page-description">@Localizer["Error.Description"]</p>
    </div>

    <section class="card">
        <div class="card-header">
            <h2 class="workspace-card-title mb-0">@Localizer["Error.RequestDetails"]</h2>
        </div>
        <div class="card-body">
            <p class="text-danger fw-semibold mb-3">@Localizer["Error.Occurred"]</p>

            @if (ShowRequestId)
            {
                <p>
                    <strong>@Localizer["Common.RequestId"]:</strong> <code>@RequestId</code>
                </p>
            }

            <h3 class="h6 mt-4">@Localizer["Error.DevelopmentMode"]</h3>
            <p>
                @Localizer["Error.DevelopmentDescription"]
            </p>
            <p class="mb-0">
                @Localizer["Error.DevelopmentWarning"]
                @Localizer["Error.DevelopmentDebugging"]
            </p>
        </div>
    </section>
</div>

@code{
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
