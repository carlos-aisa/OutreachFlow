@page "/counter"
@rendermode InteractiveServer
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> Localizer

<PageTitle>@Localizer["Sandbox.Counter.PageTitle"]</PageTitle>

<div class="page-shell">
    <div class="page-intro">
        <p class="page-kicker">@Localizer["Sandbox.Kicker"]</p>
        <h1 class="page-title">@Localizer["Sandbox.Counter.PageTitle"]</h1>
        <p class="page-description">@Localizer["Sandbox.Counter.Description"]</p>
    </div>

    <section class="card">
        <div class="card-header">
            <h2 class="workspace-card-title mb-0">@Localizer["Sandbox.Counter.StateTitle"]</h2>
        </div>
        <div class="card-body d-flex flex-wrap align-items-center gap-3">
            <p class="mb-0" role="status">@Localizer["Sandbox.Counter.CurrentCount"] <strong>@currentCount</strong></p>
            <button class="btn btn-primary" @onclick="IncrementCount">@Localizer["Sandbox.Counter.IncrementAction"]</button>
        </div>
    </section>
</div>

@code {
    private int currentCount = 0;

    private void IncrementCount()
    {
        currentCount++;
    }
}
