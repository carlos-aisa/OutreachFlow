@page "/templates"
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using Microsoft.Extensions.Localization
@using OutreachFlow.Application.Attachments
@using OutreachFlow.Application.EmailTemplates
@using OutreachFlow.Application.Templates
@using OutreachFlow.Web
@using OutreachFlow.Web.Attachments
@using OutreachFlow.Web.EmailTemplates
@inject EmailTemplateApiClient TemplateClient
@inject AttachmentAssetApiClient AttachmentClient
@inject IStringLocalizer<SharedResource> Localizer

<PageTitle>@Localizer["Templates.PageTitle"]</PageTitle>

<h1>@Localizer["Templates.PageTitle"]</h1>

<p class="text-muted">
    @Localizer["Templates.Description"]
</p>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger" role="alert">@errorMessage</div>
}

<div class="row g-4">
    <div class="col-lg-8">
        <section class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h2 class="h5 mb-0">@(editingId is null ? Localizer["Templates.Form.CreateTitle"] : Localizer["Templates.Form.EditTitle"])</h2>
                @if (editingId is not null)
                {
                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ResetForm">@Localizer["Common.CancelEdit"]</button>
                }
            </div>
            <div class="card-body">
                <EditForm Model="form" OnValidSubmit="SaveAsync">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label" for="template-name">@Localizer["Common.Name"]</label>
                            <InputText id="template-name" class="form-control" @bind-Value="form.Name" />
                        </div>
                        <div class="col-md-6 d-flex align-items-end">
                            <div class="form-check">
                                <InputCheckbox id="template-active" class="form-check-input" @bind-Value="form.IsActive" />
                                <label class="form-check-label" for="template-active">@Localizer["Common.Active"]</label>
                            </div>
                        </div>
                        <div class="col-12">
                            <label class="form-label" for="template-description">@Localizer["Common.Description"]</label>
                            <InputText id="template-description" class="form-control" @bind-Value="form.Description" />
                        </div>
                        <div class="col-12">
                            <label class="form-label" for="template-subject">@Localizer["Templates.Form.SubjectTemplate"]</label>
                            <InputText id="template-subject" class="form-control" @bind-Value="form.SubjectTemplate" />
                        </div>
                        <div class="col-12">
                            <label class="form-label" for="template-body">@Localizer["Templates.Form.BodyTemplate"]</label>
                            <InputTextArea id="template-body" class="form-control template-body" @bind-Value="form.BodyTemplate" />
                        </div>
                        <div class="col-12">
                            <button type="submit" class="btn btn-success" disabled="@isSaving">@Localizer["Templates.Form.SaveAction"]</button>
                        </div>

                        @if (editingId is not null)
                        {
                            <div class="col-12">
                                <hr />
                                <h3 class="h6">@Localizer["Templates.Attachments.DefaultTitle"]</h3>
                                <p class="text-muted small mb-2">
                                    @Localizer["Templates.Attachments.Help"]
                                </p>

                                @if (attachments.Count == 0)
                                {
                                    <p class="small mb-0">@Localizer["Templates.Attachments.Empty"]</p>
                                }
                                else
                                {
                                    <div class="list-group">
                                        @foreach (var attachment in attachments)
                                        {
                                            var isAssigned = form.DefaultAttachmentIds.Contains(attachment.Id);

                                            <div class="list-group-item d-flex justify-content-between align-items-center">
                                                <div>
                                                    <strong>@attachment.Name</strong>
                                                    <div class="small text-muted">@attachment.FileName</div>
                                                </div>
                                                @if (isAssigned)
                                                {
                                                    <button
                                                        type="button"
                                                        class="btn btn-sm btn-outline-danger"
                                                        @onclick="() => RemoveDefaultAttachmentAsync(attachment.Id)"
                                                        disabled="@isManagingAttachments">
                                                        @Localizer["Common.Remove"]
                                                    </button>
                                                }
                                                else
                                                {
                                                    <button
                                                        type="button"
                                                        class="btn btn-sm btn-outline-primary"
                                                        @onclick="() => AssignDefaultAttachmentAsync(attachment.Id)"
                                                        disabled="@isManagingAttachments">
                                                        @Localizer["Common.Add"]
                                                    </button>
                                                }
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </EditForm>
            </div>
        </section>

        <section class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h2 class="h5 mb-0">@Localizer["Templates.List.Title"]</h2>
                <span class="badge text-bg-secondary">@Localizer["Templates.List.Count", templates.Count]</span>
            </div>
            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0">
                    <thead>
                        <tr>
                            <th scope="col">@Localizer["Common.Name"]</th>
                            <th scope="col">@Localizer["Common.Subject"]</th>
                            <th scope="col">@Localizer["Templates.List.DefaultAttachments"]</th>
                            <th scope="col">@Localizer["Common.Active"]</th>
                            <th scope="col">@Localizer["Common.Actions"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (isLoading)
                        {
                            <tr><td colspan="5">@Localizer["Templates.List.Loading"]</td></tr>
                        }
                        else if (templates.Count == 0)
                        {
                            <tr><td colspan="5">@Localizer["Templates.List.Empty"]</td></tr>
                        }
                        else
                        {
                            @foreach (var template in templates)
                            {
                                <tr>
                                    <td>@template.Name</td>
                                    <td>@template.SubjectTemplate</td>
                                    <td>@template.DefaultAttachmentIds.Count</td>
                                    <td>@(template.IsActive ? Localizer["Common.Yes"] : Localizer["Common.No"])</td>
                                    <td>
                                        <button type="button" class="btn btn-sm btn-outline-primary me-2" @onclick="() => Edit(template)">@Localizer["Common.Edit"]</button>
                                        <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => DeactivateAsync(template.Id)" disabled="@(!template.IsActive)">@Localizer["Common.Deactivate"]</button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </section>
    </div>

    <div class="col-lg-4">
        <section class="card">
            <div class="card-header">
                <h2 class="h5 mb-0">@Localizer["Templates.Variables.Title"]</h2>
            </div>
            <div class="card-body">
                <p class="text-muted small">
                    @Localizer["Templates.Variables.Help"]
                </p>
                @if (variables.Count == 0)
                {
                    <p>@Localizer["Templates.Variables.Empty"]</p>
                }
                else
                {
                    <div class="list-group">
                        @foreach (var variable in variables)
                        {
                            <div class="list-group-item">
                                <code>@variable.Example</code>
                                <div class="small text-muted mt-1">@variable.Description</div>
                            </div>
                        }
                    </div>
                }
            </div>
        </section>
    </div>
</div>

@code {
    private IReadOnlyList<EmailTemplateDto> templates = [];
    private IReadOnlyList<TemplateVariableDto> variables = [];
    private IReadOnlyList<AttachmentAssetDto> attachments = [];
    private EmailTemplateFormModel form = new();
    private Guid? editingId;
    private string? errorMessage;
    private bool isLoading;
    private bool isSaving;
    private bool isManagingAttachments;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            templates = await TemplateClient.ListAsync();
            variables = await TemplateClient.ListVariablesAsync();
            attachments = await AttachmentClient.ListAsync(activeOnly: true);
        }
        catch (InvalidOperationException exception)
        {
            errorMessage = exception.Message;
        }
        catch (HttpRequestException exception)
        {
            errorMessage = $"{Localizer["Common.ApiUnavailablePrefix"]}: {exception.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SaveAsync()
    {
        isSaving = true;
        errorMessage = null;

        try
        {
            if (editingId is Guid id)
            {
                await TemplateClient.UpdateAsync(id, new UpdateEmailTemplateRequest(
                    form.Name,
                    form.Description,
                    form.SubjectTemplate,
                    form.BodyTemplate,
                    form.IsActive));
            }
            else
            {
                await TemplateClient.CreateAsync(new CreateEmailTemplateRequest(
                    form.Name,
                    form.Description,
                    form.SubjectTemplate,
                    form.BodyTemplate));
            }

            ResetForm();
            await LoadAsync();
        }
        catch (InvalidOperationException exception)
        {
            errorMessage = exception.Message;
        }
        catch (HttpRequestException exception)
        {
            errorMessage = $"{Localizer["Common.ApiUnavailablePrefix"]}: {exception.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private void Edit(EmailTemplateDto template)
    {
        editingId = template.Id;
        form = new EmailTemplateFormModel
        {
            Name = template.Name,
            Description = template.Description,
            SubjectTemplate = template.SubjectTemplate,
            BodyTemplate = template.BodyTemplate,
            IsActive = template.IsActive,
            DefaultAttachmentIds = template.DefaultAttachmentIds.ToHashSet()
        };
    }

    private async Task DeactivateAsync(Guid id)
    {
        try
        {
            await TemplateClient.DeactivateAsync(id);
            await LoadAsync();
        }
        catch (InvalidOperationException exception)
        {
            errorMessage = exception.Message;
        }
        catch (HttpRequestException exception)
        {
            errorMessage = $"{Localizer["Common.ApiUnavailablePrefix"]}: {exception.Message}";
        }
    }

    private void ResetForm()
    {
        editingId = null;
        form = new EmailTemplateFormModel();
    }

    private async Task AssignDefaultAttachmentAsync(Guid attachmentId)
    {
        if (editingId is not Guid templateId)
        {
            return;
        }

        isManagingAttachments = true;
        errorMessage = null;

        try
        {
            var updatedTemplate = await TemplateClient.AssignDefaultAttachmentAsync(templateId, attachmentId);
            ApplyUpdatedTemplate(updatedTemplate);
        }
        catch (InvalidOperationException exception)
        {
            errorMessage = exception.Message;
        }
        catch (HttpRequestException exception)
        {
            errorMessage = $"{Localizer["Common.ApiUnavailablePrefix"]}: {exception.Message}";
        }
        finally
        {
            isManagingAttachments = false;
        }
    }

    private async Task RemoveDefaultAttachmentAsync(Guid attachmentId)
    {
        if (editingId is not Guid templateId)
        {
            return;
        }

        isManagingAttachments = true;
        errorMessage = null;

        try
        {
            var updatedTemplate = await TemplateClient.RemoveDefaultAttachmentAsync(templateId, attachmentId);
            ApplyUpdatedTemplate(updatedTemplate);
        }
        catch (InvalidOperationException exception)
        {
            errorMessage = exception.Message;
        }
        catch (HttpRequestException exception)
        {
            errorMessage = $"Could not reach the OutreachFlow API: {exception.Message}";
        }
        finally
        {
            isManagingAttachments = false;
        }
    }

    private void ApplyUpdatedTemplate(EmailTemplateDto updatedTemplate)
    {
        templates = templates
            .Select(template => template.Id == updatedTemplate.Id ? updatedTemplate : template)
            .ToArray();

        if (editingId == updatedTemplate.Id)
        {
            form.DefaultAttachmentIds = updatedTemplate.DefaultAttachmentIds.ToHashSet();
        }
    }

    private sealed class EmailTemplateFormModel
    {
        [Required]
        public string Name { get; set; } = string.Empty;

        public string? Description { get; set; }

        [Required]
        public string SubjectTemplate { get; set; } = string.Empty;

        [Required]
        public string BodyTemplate { get; set; } = string.Empty;

        public bool IsActive { get; set; } = true;

        public HashSet<Guid> DefaultAttachmentIds { get; set; } = [];
    }
}
