@page "/templates"
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using OutreachFlow.Application.EmailTemplates
@using OutreachFlow.Application.Templates
@using OutreachFlow.Web.EmailTemplates
@inject EmailTemplateApiClient TemplateClient

<PageTitle>Email Templates</PageTitle>

<h1>Email Templates</h1>

<p class="text-muted">
    Store reusable subject and body templates as configurable data. Rendering and validation arrive in the next phase.
</p>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger" role="alert">@errorMessage</div>
}

<div class="row g-4">
    <div class="col-lg-8">
        <section class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h2 class="h5 mb-0">@(editingId is null ? "Create template" : "Edit template")</h2>
                @if (editingId is not null)
                {
                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ResetForm">Cancel edit</button>
                }
            </div>
            <div class="card-body">
                <EditForm Model="form" OnValidSubmit="SaveAsync">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label" for="template-name">Name</label>
                            <InputText id="template-name" class="form-control" @bind-Value="form.Name" />
                        </div>
                        <div class="col-md-6 d-flex align-items-end">
                            <div class="form-check">
                                <InputCheckbox id="template-active" class="form-check-input" @bind-Value="form.IsActive" />
                                <label class="form-check-label" for="template-active">Active</label>
                            </div>
                        </div>
                        <div class="col-12">
                            <label class="form-label" for="template-description">Description</label>
                            <InputText id="template-description" class="form-control" @bind-Value="form.Description" />
                        </div>
                        <div class="col-12">
                            <label class="form-label" for="template-subject">Subject template</label>
                            <InputText id="template-subject" class="form-control" @bind-Value="form.SubjectTemplate" />
                        </div>
                        <div class="col-12">
                            <label class="form-label" for="template-body">Body template</label>
                            <InputTextArea id="template-body" class="form-control template-body" @bind-Value="form.BodyTemplate" />
                        </div>
                        <div class="col-12">
                            <button type="submit" class="btn btn-success" disabled="@isSaving">Save template</button>
                        </div>
                    </div>
                </EditForm>
            </div>
        </section>

        <section class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h2 class="h5 mb-0">Template list</h2>
                <span class="badge text-bg-secondary">@templates.Count templates</span>
            </div>
            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0">
                    <thead>
                        <tr>
                            <th scope="col">Name</th>
                            <th scope="col">Subject</th>
                            <th scope="col">Active</th>
                            <th scope="col">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (isLoading)
                        {
                            <tr><td colspan="4">Loading templates...</td></tr>
                        }
                        else if (templates.Count == 0)
                        {
                            <tr><td colspan="4">No templates have been created yet.</td></tr>
                        }
                        else
                        {
                            @foreach (var template in templates)
                            {
                                <tr>
                                    <td>@template.Name</td>
                                    <td>@template.SubjectTemplate</td>
                                    <td>@(template.IsActive ? "Yes" : "No")</td>
                                    <td>
                                        <button type="button" class="btn btn-sm btn-outline-primary me-2" @onclick="() => Edit(template)">Edit</button>
                                        <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => DeactivateAsync(template.Id)" disabled="@(!template.IsActive)">Deactivate</button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </section>
    </div>

    <div class="col-lg-4">
        <section class="card">
            <div class="card-header">
                <h2 class="h5 mb-0">Supported variables</h2>
            </div>
            <div class="card-body">
                <p class="text-muted small">
                    These variables are centralized in Application and reused by the API and UI.
                </p>
                @if (variables.Count == 0)
                {
                    <p>No variables are available.</p>
                }
                else
                {
                    <div class="list-group">
                        @foreach (var variable in variables)
                        {
                            <div class="list-group-item">
                                <code>@variable.Example</code>
                                <div class="small text-muted mt-1">@variable.Description</div>
                            </div>
                        }
                    </div>
                }
            </div>
        </section>
    </div>
</div>

@code {
    private IReadOnlyList<EmailTemplateDto> templates = [];
    private IReadOnlyList<TemplateVariableDto> variables = [];
    private EmailTemplateFormModel form = new();
    private Guid? editingId;
    private string? errorMessage;
    private bool isLoading;
    private bool isSaving;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            templates = await TemplateClient.ListAsync();
            variables = await TemplateClient.ListVariablesAsync();
        }
        catch (InvalidOperationException exception)
        {
            errorMessage = exception.Message;
        }
        catch (HttpRequestException exception)
        {
            errorMessage = $"Could not reach the OutreachFlow API: {exception.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SaveAsync()
    {
        isSaving = true;
        errorMessage = null;

        try
        {
            if (editingId is Guid id)
            {
                await TemplateClient.UpdateAsync(id, new UpdateEmailTemplateRequest(
                    form.Name,
                    form.Description,
                    form.SubjectTemplate,
                    form.BodyTemplate,
                    form.IsActive));
            }
            else
            {
                await TemplateClient.CreateAsync(new CreateEmailTemplateRequest(
                    form.Name,
                    form.Description,
                    form.SubjectTemplate,
                    form.BodyTemplate));
            }

            ResetForm();
            await LoadAsync();
        }
        catch (InvalidOperationException exception)
        {
            errorMessage = exception.Message;
        }
        catch (HttpRequestException exception)
        {
            errorMessage = $"Could not reach the OutreachFlow API: {exception.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private void Edit(EmailTemplateDto template)
    {
        editingId = template.Id;
        form = new EmailTemplateFormModel
        {
            Name = template.Name,
            Description = template.Description,
            SubjectTemplate = template.SubjectTemplate,
            BodyTemplate = template.BodyTemplate,
            IsActive = template.IsActive
        };
    }

    private async Task DeactivateAsync(Guid id)
    {
        try
        {
            await TemplateClient.DeactivateAsync(id);
            await LoadAsync();
        }
        catch (InvalidOperationException exception)
        {
            errorMessage = exception.Message;
        }
        catch (HttpRequestException exception)
        {
            errorMessage = $"Could not reach the OutreachFlow API: {exception.Message}";
        }
    }

    private void ResetForm()
    {
        editingId = null;
        form = new EmailTemplateFormModel();
    }

    private sealed class EmailTemplateFormModel
    {
        [Required]
        public string Name { get; set; } = string.Empty;

        public string? Description { get; set; }

        [Required]
        public string SubjectTemplate { get; set; } = string.Empty;

        [Required]
        public string BodyTemplate { get; set; } = string.Empty;

        public bool IsActive { get; set; } = true;
    }
}
