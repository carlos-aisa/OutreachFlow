@page "/follow-ups"
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using Microsoft.Extensions.Localization
@using OutreachFlow.Application.Contacts
@using OutreachFlow.Application.FollowUps
@using OutreachFlow.Domain.FollowUps
@using OutreachFlow.Web
@using OutreachFlow.Web.Contacts
@using OutreachFlow.Web.FollowUps
@inject ContactApiClient ContactClient
@inject FollowUpTaskApiClient FollowUpClient
@inject IStringLocalizer<SharedResource> Localizer

<PageTitle>@Localizer["FollowUps.PageTitle"]</PageTitle>

<h1>@Localizer["FollowUps.PageTitle"]</h1>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger" role="alert">@errorMessage</div>
}

@if (!string.IsNullOrWhiteSpace(successMessage))
{
    <div class="alert alert-success" role="alert">@successMessage</div>
}

<section class="card mb-4">
    <div class="card-header">
        <h2 class="h5 mb-0">@Localizer["FollowUps.Form.Title"]</h2>
    </div>
    <div class="card-body">
        <EditForm Model="newTask" OnValidSubmit="CreateAsync">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label" for="followup-contact">@Localizer["Common.Contact"]</label>
                    <InputSelect id="followup-contact" class="form-select" @bind-Value="newTask.ContactId">
                        <option value="">@Localizer["FollowUps.Form.SelectContact"]</option>
                        @foreach (var contact in contacts)
                        {
                            <option value="@contact.Id">@contact.DisplayName (@contact.Email)</option>
                        }
                    </InputSelect>
                </div>
                <div class="col-md-3">
                    <label class="form-label" for="followup-due">@Localizer["FollowUps.Form.DueAt"]</label>
                    <InputDate id="followup-due" class="form-control" @bind-Value="newTask.DueDate" />
                </div>
                <div class="col-md-3">
                    <label class="form-label" for="followup-type">@Localizer["Common.Type"]</label>
                    <InputSelect id="followup-type" class="form-select" @bind-Value="newTask.Type">
                        @foreach (var type in FollowUpTypes)
                        {
                            <option value="@type">@FormatTaskType(type)</option>
                        }
                    </InputSelect>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button class="btn btn-primary w-100" type="submit" disabled="@isBusy">@Localizer["FollowUps.Form.CreateAction"]</button>
                </div>
                <div class="col-12">
                    <label class="form-label" for="followup-notes">@Localizer["Common.Notes"]</label>
                    <InputTextArea id="followup-notes" class="form-control" rows="3" @bind-Value="newTask.Notes" />
                </div>
            </div>
        </EditForm>
    </div>
</section>

<section class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h2 class="h5 mb-0">@Localizer["FollowUps.List.Title"]</h2>
        <div class="d-flex gap-2">
            <button class="btn btn-sm btn-outline-secondary" @onclick="ShowPendingAsync" disabled="@isBusy">@Localizer["FollowUps.List.PendingAction"]</button>
            <button class="btn btn-sm btn-outline-secondary" @onclick="ShowAllAsync" disabled="@isBusy">@Localizer["FollowUps.List.AllAction"]</button>
        </div>
    </div>
    <div class="table-responsive">
        <table class="table table-striped mb-0">
            <thead>
                <tr>
                    <th scope="col">@Localizer["Common.Due"]</th>
                    <th scope="col">@Localizer["Common.Contact"]</th>
                    <th scope="col">@Localizer["Common.Type"]</th>
                    <th scope="col">@Localizer["Common.Notes"]</th>
                    <th scope="col">@Localizer["Common.Status"]</th>
                    <th scope="col"></th>
                </tr>
            </thead>
            <tbody>
                @if (isLoading)
                {
                    <tr><td colspan="6">@Localizer["FollowUps.List.Loading"]</td></tr>
                }
                else if (tasks.Count == 0)
                {
                    <tr><td colspan="6">@Localizer["FollowUps.List.Empty"]</td></tr>
                }
                else
                {
                    @foreach (var task in tasks)
                    {
                        <tr>
                            <td>@task.DueAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                            <td><a href="@($"/contacts/{task.ContactId}")">@task.ContactDisplayName</a></td>
                            <td>@FormatTaskType(task.Type)</td>
                            <td>@(string.IsNullOrWhiteSpace(task.Notes) ? "-" : task.Notes)</td>
                            <td>@(task.IsCompleted ? Localizer["FollowUps.Status.Completed"] : Localizer["FollowUps.Status.Pending"])</td>
                            <td>
                                @if (!task.IsCompleted)
                                {
                                    <button class="btn btn-sm btn-success" @onclick="() => CompleteAsync(task.Id)" disabled="@isBusy">@Localizer["FollowUps.Actions.Complete"]</button>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</section>

@code {
    private static readonly FollowUpTaskType[] FollowUpTypes = Enum.GetValues<FollowUpTaskType>();

    private IReadOnlyList<ContactDto> contacts = [];
    private IReadOnlyList<FollowUpTaskDto> tasks = [];
    private FollowUpTaskFormModel newTask = new();
    private string? errorMessage;
    private string? successMessage;
    private bool isLoading;
    private bool isSaving;

    private bool isBusy => isLoading || isSaving;

    protected override async Task OnInitializedAsync()
    {
        await LoadContactsAsync();
        await LoadTasksAsync(isCompleted: false);
    }

    private async Task LoadContactsAsync()
    {
        contacts = await ContactClient.ListAsync(new ContactFilterRequest(
            Search: null,
            TagId: null,
            Status: null,
            DoNotContact: null,
            OrganizationId: null,
            LastContactedFrom: null,
            LastContactedTo: null));
    }

    private async Task LoadTasksAsync(bool? isCompleted)
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            tasks = await FollowUpClient.ListAsync(new FollowUpTaskFilterRequest(
                ContactId: null,
                IsCompleted: isCompleted,
                DueFrom: null,
                DueTo: null,
                Limit: null));
        }
        catch (InvalidOperationException exception)
        {
            errorMessage = exception.Message;
        }
        catch (HttpRequestException exception)
        {
            errorMessage = $"{Localizer["Common.ApiUnavailablePrefix"]}: {exception.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ShowPendingAsync()
    {
        await LoadTasksAsync(isCompleted: false);
    }

    private async Task ShowAllAsync()
    {
        await LoadTasksAsync(isCompleted: null);
    }

    private async Task CreateAsync()
    {
        isSaving = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            if (!Guid.TryParse(newTask.ContactId, out var contactId))
            {
                throw new InvalidOperationException(Localizer["FollowUps.Error.ContactRequired"]);
            }

            _ = await FollowUpClient.CreateAsync(new CreateFollowUpTaskRequest(
                contactId,
                null,
                new DateTimeOffset(newTask.DueDate.ToDateTime(new TimeOnly(9, 0)), TimeSpan.Zero),
                newTask.Type,
                newTask.Notes));

            newTask = new FollowUpTaskFormModel();
            successMessage = Localizer["FollowUps.Success.Created"];
            await LoadTasksAsync(isCompleted: false);
        }
        catch (InvalidOperationException exception)
        {
            errorMessage = exception.Message;
        }
        catch (HttpRequestException exception)
        {
            errorMessage = $"{Localizer["Common.ApiUnavailablePrefix"]}: {exception.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task CompleteAsync(Guid taskId)
    {
        isSaving = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            _ = await FollowUpClient.CompleteAsync(taskId);
            successMessage = Localizer["FollowUps.Success.Completed"];
            await LoadTasksAsync(isCompleted: false);
        }
        catch (InvalidOperationException exception)
        {
            errorMessage = exception.Message;
        }
        catch (HttpRequestException exception)
        {
            errorMessage = $"{Localizer["Common.ApiUnavailablePrefix"]}: {exception.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private string FormatTaskType(FollowUpTaskType type)
    {
        return Localizer[$"FollowUpTaskType.{type}"];
    }

    private sealed class FollowUpTaskFormModel
    {
        [Required]
        public string? ContactId { get; set; }

        [Required]
        public DateOnly DueDate { get; set; } = DateOnly.FromDateTime(DateTime.Today.AddDays(2));

        public FollowUpTaskType Type { get; set; } = FollowUpTaskType.General;

        public string? Notes { get; set; }
    }
}
