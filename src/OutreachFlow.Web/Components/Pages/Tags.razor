@page "/tags"
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using Microsoft.Extensions.Localization
@using OutreachFlow.Application.Tags
@using OutreachFlow.Web
@using OutreachFlow.Web.Tags
@inject TagApiClient TagClient
@inject IStringLocalizer<SharedResource> Localizer

<PageTitle>@Localizer["Tags.PageTitle"]</PageTitle>

<div class="page-shell">
<div class="page-intro">
    <p class="page-kicker">@Localizer["Tags.PageTitle"]</p>
    <h1 class="page-title">@Localizer["Tags.PageTitle"]</h1>
    <p class="page-description">@Localizer["Tags.Description"]</p>
</div>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger page-section" role="alert">@errorMessage</div>
}

<section class="card mb-4">
    <div class="card-header">
        <h2 class="workspace-card-title mb-0">@Localizer["Tags.Form.CreateTitle"]</h2>
    </div>
    <div class="card-body">
        <EditForm Model="newTag" OnValidSubmit="CreateTagAsync">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="row g-3 align-items-end">
                <div class="col-md-5">
                    <label class="form-label" for="tag-name">@Localizer["Common.Name"]</label>
                    <InputText id="tag-name" class="form-control" @bind-Value="newTag.Name" />
                </div>
                <div class="col-md-5">
                    <label class="form-label" for="tag-category">@Localizer["Common.Category"]</label>
                    <InputText id="tag-category" class="form-control" @bind-Value="newTag.Category" />
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-success w-100" disabled="@isSaving">@Localizer["Tags.Form.CreateAction"]</button>
                </div>
            </div>
        </EditForm>
    </div>
</section>

<section class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h2 class="workspace-card-title mb-0">@Localizer["Tags.List.Title"]</h2>
        <span class="badge text-bg-secondary">@Localizer["Tags.List.Count", tags.Count]</span>
    </div>
    <div class="table-responsive">
        <table class="table table-striped table-hover mb-0">
            <thead>
                <tr>
                    <th scope="col">@Localizer["Common.Name"]</th>
                    <th scope="col">@Localizer["Common.Category"]</th>
                    <th scope="col">@Localizer["Common.Created"]</th>
                </tr>
            </thead>
            <tbody>
                @if (isLoading)
                {
                    <tr>
                        <td colspan="3">@Localizer["Tags.List.Loading"]</td>
                    </tr>
                }
                else if (tags.Count == 0)
                {
                    <tr>
                        <td colspan="3">@Localizer["Tags.List.Empty"]</td>
                    </tr>
                }
                else
                {
                    @foreach (var tag in tags)
                    {
                        <tr>
                            <td>@tag.Name</td>
                            <td>@(tag.Category ?? "-")</td>
                            <td>@tag.CreatedAt.ToString("yyyy-MM-dd")</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</section>
</div>

@code {
    private IReadOnlyList<TagDto> tags = [];
    private TagFormModel newTag = new();
    private string? errorMessage;
    private bool isLoading;
    private bool isSaving;

    protected override async Task OnInitializedAsync()
    {
        await LoadTagsAsync();
    }

    private async Task LoadTagsAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            tags = await TagClient.ListAsync();
        }
        catch (InvalidOperationException exception)
        {
            errorMessage = exception.Message;
        }
        catch (HttpRequestException exception)
        {
            errorMessage = $"{Localizer["Common.ApiUnavailablePrefix"]}: {exception.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task CreateTagAsync()
    {
        isSaving = true;
        errorMessage = null;

        try
        {
            await TagClient.CreateAsync(new CreateTagRequest(newTag.Name, newTag.Category));
            newTag = new TagFormModel();
            await LoadTagsAsync();
        }
        catch (InvalidOperationException exception)
        {
            errorMessage = exception.Message;
        }
        catch (HttpRequestException exception)
        {
            errorMessage = $"{Localizer["Common.ApiUnavailablePrefix"]}: {exception.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private sealed class TagFormModel
    {
        [Required]
        public string Name { get; set; } = string.Empty;

        public string? Category { get; set; }
    }
}
