@inherits LayoutComponentBase
@rendermode InteractiveServer
@using Microsoft.Extensions.Localization
@using OutreachFlow.Web
@inject IStringLocalizer<SharedResource> Localizer

<div class="page">
    <aside class="sidebar">
        <NavMenu />
    </aside>

    <main class="workspace-main">
        <div class="top-row">
            <div class="top-row-shell">
                <div class="top-row-copy">
                    <p class="top-row-kicker">@Localizer["Layout.TopRowTitle"]</p>
                    <p class="top-row-caption">@Localizer["Layout.TopRowCaption"]</p>
                </div>
            </div>
        </div>

        <article class="content workspace-content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui">
    @Localizer["Layout.ErrorUnhandled"]
    <a href="" class="reload">@Localizer["Layout.ErrorReload"]</a>
    <a class="dismiss">x</a>
</div>
