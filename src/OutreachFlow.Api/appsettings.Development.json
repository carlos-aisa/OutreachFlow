{
  "ConnectionStrings": {
    "OutreachFlow": "Data Source=outreachflow.development.db"
  },
  "AttachmentStorage": {
    "RootPath": "storage/attachments"
  },
  "EmailSending": {
    "Provider": "Fake",
    "EquivalentEmailWindowHours": 168,
    "FakeFailureKeyword": "[fail-send]",
    "Smtp": {
      "Host": "",
      "Port": 587,
      "UseSsl": true,
      "Username": "",
      "Password": "",
      "TimeoutSeconds": 30
    },
    "GmailApi": {
      "Enabled": false
    },
    "MicrosoftGraph": {
      "Enabled": false
    }
  },
  "ContactSync": {
    "GoogleContacts": {
      "Enabled": false
    },
    "OutlookContacts": {
      "Enabled": false
    }
  },
  "FollowUpAutomation": {
    "AutoCreateAfterSuccessfulSend": false,
    "DueDaysAfterSend": 7,
    "DefaultType": "Email"
  },
  "Hosting": {
    "UseHttpsRedirection": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
